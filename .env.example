DATABASE_URL=your_postgres_connection_string

REDIS_URL=your_redis_url

JWT_SECRET=your_jwt_secret

PORT=4000

CORS_ORIGIN=http://localhost:3000

MAILGUN_API_KEY=your_mailgun_private_api_key

MAILGUN_DOMAIN=your_mailgun_domain

MAILGUN_FROM=MailKit <postmaster@your-domain.mailgun.org>

MAILGUN_WEBHOOK_SIGNING_KEY=your_webhook_signing_key

PUBLIC_API_URL=http://localhost:4000 // use ngrok url for live updates of status of mail from the mailgun

NEXT_PUBLIC_API_URL=http://localhost:4000